{
  "name": "@ark-preset/solid",
  "version": "0.1.2",
  "description": "Solid.js component library — Ark UI primitives styled with tailwind-variants",
  "keywords": [
    "solid-js",
    "ark-ui",
    "tailwind-variants",
    "tailwindcss",
    "ui-components",
    "design-system"
  ],
  "author": "Fandi <fandi.ilham.bb@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fanelfaa/ark-preset.git",
    "directory": "packages/solid"
  },
  "bugs": {
    "url": "https://github.com/fanelfaa/ark-preset/issues"
  },
  "homepage": "https://github.com/fanelfaa/ark-preset#readme",
  "files": [
    "dist/",
    "src/"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepublishOnly": "pnpm run build",
    "build": "vite build && tsc --build --force",
    "dev": "vite build --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ark-preset/core": "workspace:*",
    "@ark-ui/solid": "^5.0.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.0.0"
  },
  "devDependencies": {
    "@solidjs/testing-library": "^0.8",
    "@testing-library/jest-dom": "^6",
    "happy-dom": "^16",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vite-plugin-solid": "^2.0.0",
    "vitest": "^3"
  },
  "peerDependencies": {
    "solid-js": "^1.9.0",
    "tailwindcss": "^4.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
