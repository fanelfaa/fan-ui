{
  "name": "@ui/solid",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist/",
    "src/"
  ],
  "scripts": {
    "build": "vite build && tsc --build",
    "dev": "vite build --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ark-ui/solid": "^5.0.0",
    "@ui/core": "workspace:*",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.0.0"
  },
  "peerDependencies": {
    "solid-js": "^1.9.0",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vite-plugin-solid": "^2.0.0"
  }
}