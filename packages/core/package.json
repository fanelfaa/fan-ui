{
  "name": "@ark-preset/core",
  "version": "0.1.1",
  "description": "Tailwind-variants styling recipes for Ark UI primitives",
  "keywords": [
    "tailwind-variants",
    "tailwindcss",
    "ark-ui",
    "ui-components",
    "design-system",
    "styling"
  ],
  "author": "Fandi <fandi.ilham.bb@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fanelfaa/ark-preset.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/fanelfaa/ark-preset/issues"
  },
  "homepage": "https://github.com/fanelfaa/ark-preset#readme",
  "files": [
    "dist/",
    "src/"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./src/theme.css": "./src/theme.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepublishOnly": "pnpm run build",
    "build": "tsup 2>&1 | grep -E '\u26a1\ufe0f|error'",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
