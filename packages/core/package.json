{
  "name": "@ui/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./recipes/button": {
      "types": "./dist/recipes/button.d.ts",
      "import": "./dist/recipes/button.js"
    },
    "./recipes/input": {
      "types": "./dist/recipes/input.d.ts",
      "import": "./dist/recipes/input.js"
    },
    "./recipes/dialog": {
      "types": "./dist/recipes/dialog.d.ts",
      "import": "./dist/recipes/dialog.js"
    },
    "./recipes/select": {
      "types": "./dist/recipes/select.d.ts",
      "import": "./dist/recipes/select.js"
    },
    "./recipes/toast": {
      "types": "./dist/recipes/toast.d.ts",
      "import": "./dist/recipes/toast.js"
    },
    "./src/theme.css": "./src/theme.css"
  },
  "files": [
    "dist/",
    "src/"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
